{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run db:push && next build",
  "crons": [
    {
      "path": "/api/sync/events",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sync/volume",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/sync/resolution",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sync/translations",
      "schedule": "0 */6 * * *"
    }
  ],
  "ignoreCommand": "if [ \"$VERCEL_ENV\" = \"preview\" ]; then exit 0; else exit 1; fi",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  }
}
